[Unit]
Description=Driver Login Flask Application
After=network.target postgresql.service

[Service]
User=driverlogin
Group=www-data
WorkingDirectory=/opt/driver-login
EnvironmentFile=/etc/driver-login.env
ExecStart=/opt/driver-login/.venv/bin/gunicorn --config /opt/driver-login/deploy/gunicorn.conf.py wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
